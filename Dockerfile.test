# Dockerfile.test - builds and runs Signet integration tests in an isolated container

FROM golang:1.25.1-trixie AS builder

WORKDIR /workspace

# Preload modules
COPY go.mod go.sum ./
RUN go mod download

# Copy full source
COPY . .

# Build the signet-commit binary expected by the integration script
RUN go build -o signet-commit ./cmd/signet-commit

# Runtime stage with required tooling
FROM golang:1.25.1-trixie

WORKDIR /workspace

# Install dependencies needed by the integration script
RUN apt-get update \
    && apt-get install -y --no-install-recommends git gnupg \
    && rm -rf /var/lib/apt/lists/*

# Copy repository contents and the prebuilt binary
COPY . .
COPY --from=builder /workspace/signet-commit ./signet-commit

# Ensure scripts are executable
RUN chmod +x scripts/testing/test_integration.sh

# Default command runs the integration test script
CMD ["bash", "scripts/testing/test_integration.sh"]
