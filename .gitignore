# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test
!/Dockerfile.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Gitleaks scan reports
gitleaks.json

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Build artifacts
/dist/
/build/
/bin/
/signet-commit
/sigsign

# Editor/IDE specific files
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# OS specific files
.DS_Store
Thumbs.db

# Local configuration and secrets (DO NOT COMMIT)
.env
.env.local
.claude/

# Crumb tracking
.crumb/

# Agent logs and temporary directories (prefixed with _)
_*/

# Project-specific ignores
#
# Signet user data (never commit master keys!)
# Note: Ignores a .signet directory in the project root. To ignore ~/.signet
# in your home directory, add it to your global gitignore file.
.signet/
#
# Temporary test files and local experiments
experiments/
test.txt
*.sig
*.pem
#
# Internal documentation (keep locally but don't push)
INVESTIGATION_LOG.md
@INVESTIGATION_LOG.md
*_agent_log.md
AGENT_PROMPT.md
IMPLEMENTATION.md
docs/REVOCATION_IMPLEMENTATION_PLAN.md

# Local client binary for http-auth
demo/http-auth/client/client
/signet
/signet-commit

# Security audit reports (local use only)
SECURITY_AUDIT.md

# Demo binaries
client
server
signet-git
